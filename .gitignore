```gitignore
# Compiled and binary files
*.pyc
__pycache__/

# Dependencies
.venv/
venv/
node_modules/
dist/
build/
target/

# Logs and temp files
*.log
*.tmp
*.swp

# Environment
.env
.env.local
*.env.*

# Editors
.vscode/
.idea/

# Coverage and testing
.coverage
coverage/
htmlcov/

# OS specific
.DS_Store
Thumbs.db
```